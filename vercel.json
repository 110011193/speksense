{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR-APP.monsterasp.net/api/:path*"
    },

    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/calendar", "destination": "/calendar.html" },

    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/people", "destination": "/dashboard.html" },
    { "source": "/profile", "destination": "/dashboard.html" },
    { "source": "/settings", "destination": "/dashboard.html" },
    { "source": "/reports", "destination": "/dashboard.html" },
    { "source": "/configure", "destination": "/dashboard.html" },
    { "source": "/configure/:path*", "destination": "/dashboard.html" },
    { "source": "/assessments", "destination": "/dashboard.html" },
    { "source": "/assessments/:path*", "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
